# Пример конфигурации для Telegram бота сканирования
# Скопируйте этот файл в .env и заполните настройки

# ===============================================
# TELEGRAM BOT CONFIGURATION
# ===============================================

# Токен бота, полученный от @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ID пользователей, которым разрешено использовать бота
# Можно указать несколько ID через запятую
# Получить ID можно у бота @userinfobot
TELEGRAM_CHAT_IDS=123456789,987654321

# ===============================================
# SCANNER CONFIGURATION  
# ===============================================

# Устройство сканера (оставьте пустым для автоопределения)
# Можно узнать командой: scanimage -L
# Для сетевого HP по hpaio, например:
#   SCANNER_DEVICE=hpaio:/net/HP_Color_LaserJet_Pro_MFP_M177fw?ip=192.168.88.11
SCANNER_DEVICE=

# Разрешение сканирования (DPI)
SCAN_DPI=300

# Формат сохранения (PNG, JPEG)
SCAN_FORMAT=PNG

# Режим сканирования (Color, Gray, Lineart)
SCAN_MODE=Color

# Директория для сохранения сканов
# Для Docker используйте /app/scans (смонтированный volume)
SCAN_DIR=/opt/scan2telegram/scans

# ===============================================
# PRINTER CONFIGURATION
# ===============================================

# Имя принтера (можно узнать командой: lpstat -p)
PRINTER_NAME=HP_Color_LaserJet_Pro_MFP_M177fw

# Временная директория для файлов перед печатью
PRINT_TEMP_DIR=/tmp/print_queue

# --- Только для Docker: entrypoint создаёт очередь печати по этим параметрам ---
# URI устройства печати (hplip-бэкенд)
PRINTER_URI=hp:/net/HP_Color_LaserJet_Pro_MFP_M177fw?ip=192.168.88.11
# Путь к PPD внутри контейнера
PRINTER_PPD=/app/printer-m177fw.ppd

# ===============================================
# SYSTEM CONFIGURATION
# ===============================================

# Максимальный размер файла в МБ
MAX_FILE_SIZE_MB=50

# Автоудаление файлов старше X часов
CLEANUP_AFTER_HOURS=24

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ===============================================
# MONITORING (опционально, для Docker)
# ===============================================

# Uptime Kuma Push-монитор: если задан, контейнер шлёт heartbeat,
# пока бот жив (монитор зелёный). Создайте в Kuma монитор типа Push и скопируйте URL.
# KUMA_PUSH_URL=http://192.168.88.4:3001/api/push/XXXXXXXX?status=up&msg=OK
# Интервал пинга в секундах (по умолчанию 30)
# KUMA_PUSH_INTERVAL=30 